# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Email (Resend)
RESEND_API_KEY=
RESEND_FROM_EMAIL=
RESEND_FROM_NAME=AMAC Green

# PostHog Analytics
# Get your key from https://app.posthog.com/project/settings
NEXT_PUBLIC_POSTHOG_KEY=phc_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# US cloud: https://us.i.posthog.com  |  EU cloud: https://eu.i.posthog.com
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# AMAC Green — financing (server)
KCB_FINANCING_SIMULATION=false
# If set, POST /api/kcb-financing/simulate must send header x-kcb-financing-simulate-secret.
# Leave empty for local dev when calling simulate from the browser (e.g. auto-approve timer).
KCB_FINANCING_SIMULATE_SECRET=
KCB_FINANCING_AUTO_APPROVE_MS=0

# AMAC Green — financing (client)
NEXT_PUBLIC_ENABLE_FINANCING_CHECKOUT=false
NEXT_PUBLIC_SHOW_FINANCING_SIMULATION_UI=false
NEXT_PUBLIC_KCB_FINANCING_AUTO_APPROVE_MS=0

# Demand profile wizard
NEXT_PUBLIC_ENABLE_DEMAND_PROFILE=false

# Checkout: category slug for enhanced Kenya location fields
NEXT_PUBLIC_ENHANCED_LOCATION_CATEGORY_SLUG=gas-yetu

# Orders: when true, orders are not saved to DB (dev only). Success page uses a session snapshot.
ORDER_SIMULATION=false

# M-Pesa Daraja — STK Push CallBackURL must be a public HTTPS URL (Safaricom rejects localhost).
# For local dev, expose the app with ngrok (or similar) and set the full callback route:
# MPESA_CALLBACK_URL=https://YOUR_SUBDOMAIN.ngrok-free.app/api/daraja/callback
MPESA_CALLBACK_URL=
